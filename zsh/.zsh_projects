# 프로젝트 경로 설정
workspacePath="/Users/zero/Workspace"

# 프로젝트별 별칭
alias showket="code $workspacePath/actbase/showket-app/. && exit"
alias r114="code $workspacePath/mih/r114/. && exit"
alias calendar="code $workspacePath/mih/CalenderTS/. && exit"
alias tnit="code $workspacePath/mih/teuni-teacher/. && exit"
alias tniu="code $workspacePath/mih/teuni-user/. && exit"
alias ww="code $workspacePath/walrus/warlus-web/. && exit"
alias epit="code $workspacePath/walrus/e-pit/acteevApp/. && exit"
alias uibuilder="code $workspacePath/walrus/zinc-ui-builder/. && exit"
alias bsapp="code $workspacePath/walrus/blowsome-app/. && exit"
alias bsadmin="code $workspacePath/walrus/blowsome-admin/. && exit"
alias bsapi="code $workspacePath/walrus/blowsome-api/. && exit"
alias jsr="code $workspacePath/walrus/jsr-xhaust/. && exit"
alias jsrserver="code $workspacePath/walrus/jsr-xhaust-server/. && exit"
alias salus="code $workspacePath/walrus/salus/. && exit"
alias bot="code $workspacePath/Game/hoengbot/. && exit"
alias outsource="code $workspacePath/Game/outSourcing/Bots/outsourcing/. && exit"

# Mazzum
alias cdmazzum="cd $workspacePath/matchtech/mazzum/."
alias mazzum="code $workspacePath/matchtech/mazzum/. && exit"
alias cdmazzumDev="cd $workspacePath/matchtech/mazzum_dev/."
alias mazzumDev="code $workspacePath/matchtech/mazzum_dev/. && exit"
alias cdmazzumWeb="cd $workspacePath/matchtech/mazzum_web/."
alias mazzumWeb="code $workspacePath/matchtech/mazzum_web/. && exit"
alias cdmazzumSWeb="cd $workspacePath/matchtech/mazzum-static-web/."
alias mazzumSWeb="code $workspacePath/matchtech/mazzum-static-web/. && exit"
alias cdmazzumAdmin="cd $workspacePath/matchtech/mazzum-admin/."
alias mazzumAdmin="code $workspacePath/matchtech/mazzum-admin/. && exit"
alias cdmazzumApi="cd $workspacePath/matchtech/mazzum-api/."
alias mazzumApi="code $workspacePath/matchtech/mazzum-api/. && exit"

# 패키지 이름 및 MainActivity 설정
BSP="com.jsr.blowsome"
BS="com.jsr.blowsome/com.jsr.blowsome.MainActivity"
BSPD="com.jsr.blowsome.debug"
BSD="com.jsr.blowsome.debug/com.jsr.blowsome.MainActivity"
XHP="com.jsr_1"
XH="com.jsr_1/com.jsr_1.MainActivity"
EPP="com.hyundai.acteev"
EP="com.hyundai.acteev/.MainActivity"
EPPS="com.hyundai.acteev.staging"
EPS="com.hyundai.acteev.staging/com.hyundai.acteev.MainActivity"
SPP="com.salus"
SP="com.salus/.MainActivity"
MPP="com.mazzum.develop"
MP="com.mazzum.develop/.MainActivity"

# 임시 타겟 설정
target="$EP"
targetP="$EPP"
targetD="$MPP"
targetDP="$MP"

# 타겟 관련 별칭
alias y1="adb+ shell am start -n $target"
alias y2="adb+ shell am force-stop $targetP"
alias y3="adb+ shell pm clear $targetP"
alias y4="adb+ uninstall $targetP"
alias yd1="adb+ shell am start -n $targetD"
alias yd2="adb+ shell am force-stop $targetDP"
alias yd3="adb+ shell pm clear $targetDP"
alias yd4="adb+ uninstall $targetDP"
alias ydd="yd2 && yd3 && yd4 && adb install *.apk && sleep 2 && yd1"
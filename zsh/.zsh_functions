alias gcbt="git-commits-by-target"
function git-commits-by-target() {
  local days=${1:-7}
  
  # 타겟 목록 추출
  local targets=$(git log --author="ZeroMatchtech" --pretty=format:"%s" --since="$days days ago" | 
                 grep -v "Merge branch" | 
                 grep -o "\[[^]]*\]" | 
                 sort | 
                 uniq)
  
  {
    # 각 타겟별로 처리
    echo "$targets" | while read target; do
      if [ -n "$target" ]; then
        echo -e "\nㅁ ${target}";
        git log --author="ZeroMatchtech" --pretty=format:"%s" --since="$days days ago" | 
        grep -v "Merge branch" | 
        grep -F "$target" | 
        sed -E "s/\\${target}[[:space:]]*/ - /"
      fi
    done
  } | tee /dev/tty | pbcopy
  
  echo -e "\n결과가 클립보드에 복사되었습니다."
}


function appInTossFC() {
  if [ $1 ]; then
    local target=$1
    local withClose=${2:-true}  # 기본값은 true (기존 동작 유지)
    
    # withClose가 true일 때만 terminate 실행
    if [ "$withClose" = "true" ]; then
      xcrun simctl terminate "iPhone 16" kr.co.matchtech.mazzum.develop
      xcrun simctl terminate "iPhone 16 Pro" kr.co.matchtech.mazzum.develop
      xcrun simctl terminate "iPhone 16 Pro Max" kr.co.matchtech.mazzum.develop
    fi

    xcrun simctl openurl "iPhone 16" "intoss://test-mazzum-miniapp?target=$target"
    xcrun simctl openurl "iPhone 16 Pro" "intoss://test-mazzum-miniapp?target=$target"
    xcrun simctl openurl "iPhone 16 Pro Max" "intoss://test-mazzum-miniapp?target=$target"

    # 연결된 모든 안드로이드 기기 목록 가져오기
    local devices=($(adb devices | grep -w "device" | grep -v "List" | awk '{print $1}'))

    if [ ${#devices[@]} -eq 0 ]; then
      echo "연결된 안드로이드 기기가 없습니다."
      return 1
    fi

    local android_param=$(echo "$target" | sed 's/&/\\&/g')
    
    echo "연결된 기기 ${#devices[@]}개에 딥링크 발송 중..."
    for device in "${devices[@]}"; do
      # Android 버전 확인 (API 레벨)
      api_level=$(adb -s "$device" shell getprop ro.build.version.sdk 2>/dev/null | tr -d '\r')
      android_version=$(adb -s "$device" shell getprop ro.build.version.release 2>/dev/null | tr -d '\r')
      
      echo "기기 $device (Android $android_version, API $api_level)에 발송 중..."
      
      # API 35 (Android 15) 이상인지 확인
      if [ "$api_level" -ge 35 ]; then
        echo "  → Android 15+ 기기로 감지됨"
      else
        echo "  → Android 14 이하 기기로 감지됨"
      fi
      
      adb -s "$device" shell am start -W -a android.intent.action.VIEW -d "intoss://test-mazzum-miniapp?target=$android_param"
    done
  fi
}

# scrcpy 관련 함수
function spyFC() {
  local device=$1
  local config_file="$HOME/.scrcpy_config"
  local command="scrcpy -s $device --always-on-top --stay-awake --turn-screen-off --disable-screensaver --max-fps 60 --video-bit-rate 16M --shortcut-mod=lalt --no-audio"
  eval "$command"
}

function update_window_info() {
  window_info=$(osascript -e '
    tell application "System Events"
      set scrcpyProcess to first process whose name contains "scrcpy"
      if exists scrcpyProcess then
        set scrcpyWindow to first window of scrcpyProcess
        set {x, y} to position of scrcpyWindow
        set {width, height} to size of scrcpyWindow
        return x & y & width & height
      else
        return "not_found"
      end if
    end tell
  ')

  if [ "$window_info" != "not_found" ]; then
    # 모든 공백 제거
    window_info=$(echo "$window_info" | tr -d ' ')
    # 쉼표로 구분된 값을 배열로 변환 (zsh 방식)
    info_array=(${(s:,:)window_info})
    # 배열에 4개의 요소가 있는지 확인
    echo $info_array
    if [ ${#info_array[@]} -eq 4 ]; then
      window_x=${info_array[1]}
      window_y=${info_array[2]}
      window_width=${info_array[3]}
      window_height=${info_array[4]}
      # 설정 파일 업데이트
      echo "window_x=$window_x" > "$config_file"
      echo "window_y=$window_y" >> "$config_file"
      echo "window_width=$window_width" >> "$config_file"
      echo "window_height=$window_height" >> "$config_file"
      
      echo "창 정보가 업데이트되었습니다: x=$window_x, y=$window_y, width=$window_width, height=$window_height"
    else
      echo "창 정보 형식이 올바르지 않습니다: $window_info"
    fi
  else
    echo "scrcpy 창을 찾을 수 없습니다."
  fi
}

function cleanup() {
  local pid=$1
  echo "정리 작업 수행 중..."
  if ps -p $pid > /dev/null 2>&1; then
    echo "scrcpy 프로세스 (PID: $pid) 종료 중..."
    kill $pid
    sleep 1
    if ps -p $pid > /dev/null 2>&1; then
      echo "scrcpy 프로세스가 여전히 실행 중입니다. 강제 종료합니다."
      kill -9 $pid
    fi
  fi
  close_scrcpy_window
  echo "정리 작업 완료."
}

function close_scrcpy_window() {
  osascript -e '
    tell application "System Events"
      set scrcpyProcess to first process whose name contains "scrcpy"
      if exists scrcpyProcess then
        set scrcpyWindow to first window of scrcpyProcess
        click button 1 of scrcpyWindow
      end if
    end tell
  '
}

# adb 관련 함수
function adb+() {
  adb devices | while read -r line
  do
  if [ ! "$line" = "" ] && [ "$(echo "$line" | awk '{print $2}')" = "device" ]
  then
      device=$(echo "$line" | awk '{print $1}')
      echo "$device" "$@" ...
      adb -s "$device" "$@"
  fi
  done
}

port="8081"
function adbrFC() {
  if [ $1 ]; then
    eval "adb+ reverse tcp:$1 tcp:$1"
    eval "port=$1"
  elif [ -n "$port" ]; then
    eval "adb+ reverse tcp:$port tcp:$port"
  fi
}

function adbkFC() {
  if [ $1 ]; then
    eval _package=$(echo $1 | cut -d '/' -f1) && echo $_package
    eval "adb+ shell am force-stop $_package"
    eval "package=$_package"
  elif [ -n "$package" ]; then
    eval "adb+ shell am force-stop $package"
  fi
}

function adbsFC() {
  if [ $1 ]; then
    eval "adb+ shell am start -n $1"
    eval package=$(echo $1 | cut -d '/' -f1) && echo $package
    eval "activity=$1"
  elif [ -n "$activity" ]; then
    eval "adb+ shell am start -n $activity"
  fi
}


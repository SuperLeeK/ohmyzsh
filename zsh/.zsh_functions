function gitdeployclear() {
  local keep_count=${1:-2}  # 기본값 2개 보존
  local current_user=$(git config user.name)
  
  echo "현재 사용자: $current_user"
  echo "최신 ${keep_count}개씩 보존합니다"
  echo ""
  
  # 모든 deploy 브랜치들 가져오기 (최신순 비교용)
  local all_deploy_branches=()
  local my_deploy_branches=()
  
  while IFS= read -r branch; do
    branch=$(echo $branch | xargs)  # 공백 제거
    author=$(git for-each-ref --format='%(authorname)' refs/heads/$branch)
    all_deploy_branches+=("$branch")
    if [[ "$author" == "$current_user" ]]; then
      my_deploy_branches+=("$branch")
    fi
  done <<< "$(git branch | grep 'deploy/')"
  
  if [[ ${#my_deploy_branches[@]} -eq 0 ]]; then
    echo "본인이 생성한 deploy 브랜치가 없습니다."
    return
  fi
  
  echo "전체 deploy 브랜치: ${#all_deploy_branches[@]}개"
  echo "본인 deploy 브랜치: ${#my_deploy_branches[@]}개"
  
  echo "=== 모든 브랜치를 날짜순으로 정렬 ==="
  
  # 모든 브랜치를 날짜순으로 정렬 (최신순) - 최신 기준 판단용
  local sorted_all_branches=($(printf '%s\n' "${all_deploy_branches[@]}" | sort -t'/' -k4,4nr))
  
  echo "정렬된 전체 브랜치 목록:"
  for branch in "${sorted_all_branches[@]}"; do
    author=$(git for-each-ref --format='%(authorname)' refs/heads/$branch)
    echo "  $branch (작성자: $author)"
  done
  
  # 각 platform/target 조합의 최신 상태 추적
  declare -A latest_for_combination
  
  # target/platform 조합들 (all과 both 제거)
  local all_combinations=("usr_web" "usr_app" "csr_web" "csr_app")
  
  for branch in "${sorted_all_branches[@]}"; do
    PARTS=(${(s:/:)branch})
    if [[ ${#PARTS[@]} -eq 6 ]]; then
      local date_part=${PARTS[4]}
      local target=${PARTS[5]}    # usr/csr
      local platform=${PARTS[6]}  # web/app
      
      echo "처리 중: $branch (날짜: $date_part, 타겟: $target, 플랫폼: $platform)"
      
      # 개별 조합만 처리 (all/both 없음)
      local combo="${target}_${platform}"
      if [[ -z "${latest_for_combination[$combo]}" ]]; then
        latest_for_combination[$combo]="$branch"
        echo "  -> $combo 조합의 최신으로 설정"
      fi
    fi
  done
  
  echo ""
  echo "=== 각 조합별 최신 브랜치 ==="
  for combo in "${(@k)latest_for_combination}"; do
    echo "$combo: ${latest_for_combination[$combo]}"
  done
  
  echo ""
  echo "=== 보존될 브랜치들 계산 중 ==="
  
  # 보존할 브랜치들 선별 (각 조합별로 최신 keep_count개, 단 본인 브랜치만)
  declare -A preserve_branches
  for combo in "${all_combinations[@]}"; do
    local combo_branches=()
    for branch in "${sorted_all_branches[@]}"; do
      # 본인 브랜치인지 확인
      local is_my_branch=false
      for my_branch in "${my_deploy_branches[@]}"; do
        if [[ "$branch" == "$my_branch" ]]; then
          is_my_branch=true
          break
        fi
      done
      
      # 본인 브랜치가 아니면 건너뛰기
      if [[ "$is_my_branch" == "false" ]]; then
        continue
      fi
      PARTS=(${(s:/:)branch})
      if [[ ${#PARTS[@]} -eq 6 ]]; then
        local target=${PARTS[5]}
        local platform=${PARTS[6]}
        local current_combo="${target}_${platform}"
        
        # 현재 조합과 일치하는 브랜치만 추가
        if [[ "$current_combo" == "$combo" ]]; then
          combo_branches+=("$branch")
        fi
      fi
    done
    
    # 이 조합에서 최신 keep_count개 보존
    for (( i=0; i<$keep_count && i<${#combo_branches[@]}; i++ )); do
      preserve_branches["${combo_branches[$i]}"]="1"
      echo "보존: ${combo_branches[$i]} (조합 $combo의 $((i+1))번째)"
    done
  done
  
  # 삭제할 브랜치들 결정 (본인 브랜치 중에서만)
  local branches_to_delete=()
  for branch in "${my_deploy_branches[@]}"; do
    if [[ -z "${preserve_branches[$branch]}" ]]; then
      branches_to_delete+=("$branch")
    fi
  done
  
  # 삭제 실행 (일단 목록만 표시)
  if [[ ${#branches_to_delete[@]} -gt 0 ]]; then
    echo ""
    echo "=== 삭제될 deploy 브랜치들 ==="
    printf '%s\n' "${branches_to_delete[@]}"
    echo ""
    echo "실제 삭제를 원하면 함수 내의 주석을 해제하세요."
    # printf '%s\n' "${branches_to_delete[@]}" | xargs -I {} git branch -D {}
    # echo "로컬 deploy 브랜치 삭제 완료"
  else
    echo "삭제할 deploy 브랜치가 없습니다."
  fi
}

function gittagclear() {
  local keep_count=${1:-5}  # 기본값 5개 보존
  local current_user=$(git config user.name)
  
  echo "현재 사용자: $current_user"
  echo "각 platform/target 조합별로 최신 ${keep_count}개씩 보존합니다"
  echo ""
  
  # deploy로 시작하는 모든 태그 가져오기
  local all_deploy_tags=($(git tag -l "deploy/*" | sort))
  
  if [[ ${#all_deploy_tags[@]} -eq 0 ]]; then
    echo "deploy 태그가 없습니다."
    return
  fi
  
  echo "전체 deploy 태그: ${#all_deploy_tags[@]}개"
  
  # platform/target 조합별로 그룹핑
  declare -A platform_target_groups
  
  for tag in "${all_deploy_tags[@]}"; do
    # deploy/prd/1.5.0/2509011213/usr/web 형태 파싱 (target/platform 순서)
    PARTS=(${(s:/:)tag})
    if [[ ${#PARTS[@]} -eq 6 ]]; then
      local env=${PARTS[2]}        # prd/stg
      local version=${PARTS[3]}    # 1.5.0
      local date_part=${PARTS[4]}  # 2509011213
      local target=${PARTS[5]}     # usr/csr
      local platform=${PARTS[6]}   # web/app
      
      local group_key="${env}_${version}_${target}_${platform}"
      
      if [[ -z "${platform_target_groups[$group_key]}" ]]; then
        platform_target_groups[$group_key]="$tag"
      else
        platform_target_groups[$group_key]="${platform_target_groups[$group_key]} $tag"
      fi
    fi
  done
  
  local tags_to_delete=()
  
  echo "=== 각 조합별 태그 정리 ==="
  for group_key in "${(@k)platform_target_groups}"; do
    local group_tags=(${(s: :)platform_target_groups[$group_key]})
    
    # 날짜 기준 내림차순 정렬 (최신순)
    local sorted_group=($(printf '%s\n' "${group_tags[@]}" | sort -t'/' -k4,4nr))
    
    echo "그룹 $group_key: ${#sorted_group[@]}개 태그"
    
    # 최신 keep_count개 보존, 나머지 삭제 대상에 추가
    for (( i=0; i<${#sorted_group[@]}; i++ )); do
      if [[ $i -lt $keep_count ]]; then
        echo "  보존: ${sorted_group[$i]}"
      else
        echo "  삭제: ${sorted_group[$i]}"
        tags_to_delete+=("${sorted_group[$i]}")
      fi
    done
    echo ""
  done
  
  # 삭제 실행 (일단 목록만 표시)
  if [[ ${#tags_to_delete[@]} -gt 0 ]]; then
    echo "=== 삭제될 태그들 ==="
    printf '%s\n' "${tags_to_delete[@]}"
    echo ""
    echo "실제 삭제를 원하면 아래 주석을 해제하세요:"
    echo "# printf '%s\\n' \"\${tags_to_delete[@]}\" | xargs -I {} git tag -d {}"
    echo "# git push origin \$(printf ':%s ' \"\${tags_to_delete[@]}\")"
    
    # 실제 삭제 명령어 (주석 처리)
    # printf '%s\n' "${tags_to_delete[@]}" | xargs -I {} git tag -d {}
    # git push origin $(printf ':%s ' "${tags_to_delete[@]}")
    # echo "로컬 및 리모트 태그 삭제 완료"
  else
    echo "삭제할 태그가 없습니다."
  fi
}

# 주간 업무 보고용 git 로그 추출 함수
# 사용법: git-weekly YYMMDD YYMMDD
function git-weekly() {
    if [ "$#" -ne 2 ]; then
        echo "Usage: git-weekly <StartDate YYMMDD> <EndDate YYMMDD>"
        echo "Example: git-weekly 251219 251226"
        return 1
    fi

    local start_input=$1
    local end_input=$2

    # 날짜 포맷 변환 (YYMMDD -> YYYY-MM-DD)
    # macOS date 명령어 사용 (-j -f)
    local start_date=$(date -j -f "%y%m%d" "$start_input" "+%Y-%m-%d")
    local end_date=$(date -j -f "%y%m%d" "$end_input" "+%Y-%m-%d")

    echo "📅 조회 기간: $start_date ~ $end_date"

    git log --author="ZeroMatchtech" \
        --since="$start_date" \
        --until="$end_date 23:59:59" \
        --pretty=format:"%s" \
        --no-merges | \
    sort | \
    awk '
    {
        if (match($0, /^\[[^]]+\]/)) {
            cat = substr($0, RSTART, RLENGTH)
            msg = substr($0, RSTART + RLENGTH)
            sub(/^ */, "", msg)
        } else {
            cat = "[기타]"
            msg = $0
        }
        if (cat != prev_cat) {
            if (NR > 1) print ""
            print cat
            prev_cat = cat
        }
        print "- " msg
    }'
}

function gitbranchclear() {
  local current_user=$(git config user.name)
  echo "현재 사용자: $current_user"
  echo ""
  
  # 로컬에서 본인이 생성한 feature 브랜치 중 develop에 머지된 것들
  echo "=== 삭제될 로컬 feature 브랜치들 (본인 생성) ==="
  local local_branches=$(git branch --merged develop | grep "feature/" | while read branch; do
    branch=$(echo $branch | xargs)  # 공백 제거
    author=$(git for-each-ref --format='%(authorname)' refs/heads/$branch)
    if [[ "$author" == "$current_user" ]]; then
      echo $branch
    fi
  done)
  
  if [[ -n "$local_branches" ]]; then
    echo "$local_branches"
    echo "$local_branches" | xargs -I {} git branch -d {}
    echo "로컬 브랜치 삭제 완료"
  else
    echo "삭제할 로컬 브랜치가 없습니다."
  fi
  
  echo ""
  
  # 리모트에서 본인이 생성한 feature 브랜치 중 develop에 머지된 것들
  echo "=== 삭제될 리모트 feature 브랜치들 (본인 생성) ==="
  local remote_branches=$(git branch -r --merged develop | grep "origin/feature/" | while read branch; do
    branch=$(echo $branch | xargs | sed 's/origin\///')  # origin/ 제거 및 공백 제거
    author=$(git for-each-ref --format='%(authorname)' refs/remotes/origin/$branch)
    if [[ "$author" == "$current_user" ]]; then
      echo $branch
    fi
  done)
  
  if [[ -n "$remote_branches" ]]; then
    echo "$remote_branches"
    echo "$remote_branches" | xargs -I {} git push --delete origin {}
    echo "리모트 브랜치 삭제 완료"
  else
    echo "삭제할 리모트 브랜치가 없습니다."
  fi
}


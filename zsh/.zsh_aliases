# Git 관련 별칭
alias gi="gInit"
alias g1="git log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr)%C(bold blue)<%an>%Creset' --abbrev-commit"
alias gg="git log"
alias gd="gdFC"
alias ga="gaFC"
alias gr="grFC"
alias gb='gbFC'
alias gsw='gswFC'
alias gco="gcoFC"
alias gl="git pull"
alias gp='git push'
alias gs='git status'
alias gcm='git commit -m'
alias ㅎ츠='gcm'
alias gcma='git commit -a -m'
alias gca='git commit --amend'
alias gitsubpull="git submodule foreach git pull"
alias gitsubinit="git submodule update --init --recursive"
git-stash-apply-by-message() {
    local message="$1"
    local stash_index=$(git stash list | grep "$message" | head -1 | sed 's/stash@{\([0-9]*\)}.*/\1/')
    if [ -n "$stash_index" ]; then
        git stash apply "stash@{$stash_index}"
    else
        echo "Stash with message '$message' not found"
    fi
}
alias gsam="git-stash-apply-by-message"
alias gsame="git-stash-apply-by-message \"exclude_not_ts_file_with_folders\""
alias gssiu="git stash save $@ --include-untracked"

